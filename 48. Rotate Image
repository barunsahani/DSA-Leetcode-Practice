//Bruteforce using ans n*n array then copying back


class Solution {
    public void rotate(int[][] matrix) {
        int n = matrix.length;
        int m = matrix[0].length;
        int[][] ans = new int[n][m];

        for(int i = 0; i < n; i++) {
            for(int j = 0; j < m; j++) {
                ans[j][(n-1)-i] = matrix[i][j];
            }
        }

        for(int i = 0; i < n; i++) {
            for(int j = 0; j < m; j++) {
                matrix[i][j] = ans[i][j];
            }
        }
    }
}




//Optimal Approach


class Solution {
    public void rotate(int[][] matrix) {
        int n = matrix.length;
        
        
        //Transpose
        for(int i = 0; i < n - 1; i++) {
            for(int j = i+1; j < n ; j++) {
                int temp;
                temp = matrix[i][j];
                matrix[i][j] = matrix[j][i];
                matrix[j][i] = temp;
            }

        }

        //reverse each rows
         for(int i = 0; i < n; i++) {
            for(int j = 0; j < n / 2; j++) {
                int temp = matrix[i][j];
                matrix[i][j] = matrix[i][n-1-j];
                matrix[i][n-1-j] = temp;
            }
         }

       
    }
}
