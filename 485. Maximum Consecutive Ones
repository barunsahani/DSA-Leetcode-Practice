//OPtimal and better are similar

class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int max = 0;
        int count = 0;
        int n = nums.length;

        for(int i = 0; i < n; i++){          //in optimal we use for-each loop
            if(nums[i] == 1){
                count++;
                max = Math.max(max,count);
            } else {
                count = 0;
            }
        }
        return max;
    }
}


//BruteForce  (time limit exceeded )

class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int n = nums.length;
        int max = 0;

        for(int i = 0; i < n; i++) {
            if(nums[i] == 1) {
                int count = 0;
                for(int j = i; j < n && nums[j] == 1; j++) {
                    count++;
                }
                max = Math.max(max, count);
            }
        }
        return max;
    }
}
