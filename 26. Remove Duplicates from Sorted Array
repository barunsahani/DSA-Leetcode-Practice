//BruteForce (better) (Not working for all cases , order is not sorted)
import java.util.*;

class Solution {

    public int removeDuplicates(int[] nums) {
        Set<Integer> set = new HashSet<>();          //To maintain sorted order we use LinkedHashSet and it works (accepted)
        for(int i = 0; i < nums.length; i++){
            set.add(nums[i]);
        }
        int index = 0;
        for(int n : set){
            nums[index] = n;
            index++;
        }
        return index;
    }
}





//Optimal Approach
class Solution {

    public int removeDuplicates(int[] nums) {
        int i = 0;
        int n = nums.length;
        for(int j = 1; j < n; j++){
            if(nums[j] != nums[i]){
                nums[i+1] = nums[j];
                i++;
            }
        }
        return i+1;
    }
}



//Bruteforce using nested loops

class Solution {
    public int removeDuplicates(int[] nums) {
        int n = nums.length;

        for(int i = 0; i < n; i++) {
            for(int j = i + 1; j < n; j++) {

                if(nums[i] == nums[j]) {
                    for(int k = j; k < n - 1; k++) {
                        nums[k] = nums[k + 1];
                    }
                    n--;
                    j--;
                }
            }
        }
        return n;
    }
}
