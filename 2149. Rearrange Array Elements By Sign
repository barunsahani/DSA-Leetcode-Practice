//BruteForce Approach

class Solution {
    public int[] rearrangeArray(int[] nums) {
        int n = nums.length;
        int[] pos = new int[n/2];
        int[] neg = new int[n/2];
        int j = 0, k = 0;

        for(int i = 0; i < n; i++) {
            if(nums[i] > 0) {
                pos[j] = nums[i];
                j++;
            } else {
                neg[k] = nums[i];
                k++;
            }
        }

        j = 0;
        k = 0;
        for(int i = 0; i < n / 2; i++) {
            nums[2*i]  = pos[j];

            nums[2*i + 1]  = neg[k];
            j++;
            k++;
        }

        return nums;
    }
}


//Optimal Approach

class Solution {
    public int[] rearrangeArray(int[] nums) {
        int[] res = new int[nums.length];
        int even = 0, odd = 1;

        for (int i = 0; i < nums.length; i++) {
            if (nums[i] > 0) {
                res[even] = nums[i];
                even += 2;
            } else {
                res[odd] = nums[i];
                odd += 2;
            }
        }
        return res;

        
    }
}


