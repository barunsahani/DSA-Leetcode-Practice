class Solution {

    public int minDays(int[] bloomDay, int m, int k) {
        long required = (long) m * k;

        // Impossible case
        if (required > bloomDay.length) return -1;

        int minDay = Integer.MAX_VALUE;
        int maxDay = Integer.MIN_VALUE;

        // Find min & max bloom day
        for (int d : bloomDay) {
            minDay = Math.min(minDay, d);
            maxDay = Math.max(maxDay, d);
        }

        int low = minDay, high = maxDay;
        int result = -1;

        // Binary Search on answer (days)
        while (low <= high) {
            int mid = low + (high - low) / 2;

            if (canMake(bloomDay, mid, m, k)) {
                result = mid;      // possible → try smaller day
                high = mid - 1;
            } else {
                low = mid + 1;    // not possible → need more days
            }
        }

        return result;
    }

    private boolean canMake(int[] bloomDay, int day, int m, int k) {
        int count = 0;
        int bouquets = 0;

        for (int d : bloomDay) {
            if (d <= day) {
                count++;
                if (count == k) {
                    bouquets++;
                    count = 0;
                }
            } else {
                count = 0;
            }
        }

        return bouquets >= m;
