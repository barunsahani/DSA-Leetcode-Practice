//BruteForce Approach   ( T.C : O(n) , S.C : O(1) )   //Time limit exceeded

public double myPow(double x, int n) {
    double result = 1.0;
    long N = n; // handle negative safely
    
    if (N < 0) {
        x = 1 / x;
        N = -N;
    }

    for (long i = 0; i < N; i++) {
        result *= x;
    }
    return result;
}





//Better Approach     ( T.C : O(logn) ,  S.C : O(logn) )  //recursive stack


class Solution {
    public double myPow(double x, int n) {
        long N = n;
        
        if (N < 0) {
            x = 1 / x;
            N = -N;
        }
        
        return fastPow(x, N);
    }

    private double fastPow(double x, long n) {
        if (n == 0) return 1.0;

        double half = fastPow(x, n / 2);

        return (n % 2 == 0) 
            ? half * half 
            : half * half * x;
    }
}



//Best Approach       ( T.C : O(logn) , S.C : O(1) )


class Solution {
    public double myPow(double x, int n) {
        long N = n;           //
        
        if (N < 0) {
            x = 1 / x;
            N = -N;
        }

        double result = 1.0;

        while (N > 0) {
            if ((N & 1) == 1) {
                result *= x;
            }
            x *= x;
            N >>= 1;
        }

        return result;
    }
}


